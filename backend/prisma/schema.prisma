generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  ADMIN
  SUPER_ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  UNPAID
  PAID
  PARTIALLY_REFUNDED
  REFUNDED
  FAILED
}

enum SubscriptionPlan {
  BASIC
  PREMIUM
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  TRIAL
}

enum PaymentProvider {
  STRIPE      // Visa / Mastercard
  NOTCHPAY    // Orange Money CM, MTN Mobile Money CM, cartes locales
}

enum PaymentMethod {
  CARD
  ORANGE_MONEY
  MTN_MOBILE_MONEY
}

enum PaymentTransactionStatus {
  PENDING    // initié, en attente de confirmation (Mobile Money OTP)
  SUCCESS    // confirmé par webhook
  FAILED     // refusé / timeout
  CANCELLED  // annulé par l'utilisateur
  EXPIRED    // délai dépassé sans confirmation
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
  RETURN
}

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  passwordHash      String    @map("password_hash")
  fullName          String    @map("full_name")
  phone             String?
  role              UserRole  @default(CUSTOMER)
  isEmailVerified   Boolean   @default(false) @map("is_email_verified")
  emailVerifyToken  String?   @map("email_verify_token")
  passwordResetToken String?  @map("password_reset_token")
  passwordResetExpiry DateTime? @map("password_reset_expiry")
  refreshTokens     RefreshToken[]
  orders            Order[]
  subscriptions     Subscription[]
  payments          Payment[]
  addresses         Address[]
  carbonProfiles    CarbonProfile[]
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])            // M11 — nettoyage périodique des tokens expirés
  @@index([userId, expiresAt])    // M11 — révocation rapide par utilisateur
  @@map("refresh_tokens")
}

model Address {
  id         String  @id @default(uuid())
  userId     String  @map("user_id")
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  street     String
  city       String
  region     String?
  country    String  @default("CM")
  postalCode String? @map("postal_code")
  isDefault  Boolean @default(false) @map("is_default")
  orders     Order[]
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("addresses")
}

model Category {
  id              String    @id @default(uuid())
  slug            String    @unique
  nameEn          String    @map("name_en")
  nameFr          String    @map("name_fr")
  descriptionEn   String?   @map("description_en")
  descriptionFr   String?   @map("description_fr")
  iconUrl         String?   @map("icon_url")
  ecoScore        Int       @default(0) @map("eco_score") // 0-100 green rating
  parentId        String?   @map("parent_id")
  parent          Category? @relation("CategoryTree", fields: [parentId], references: [id])
  children        Category[] @relation("CategoryTree")
  products        Product[]
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@map("categories")
}

model Product {
  id                String    @id @default(uuid())
  sku               String    @unique
  nameEn            String    @map("name_en")
  nameFr            String    @map("name_fr")
  descriptionEn     String?   @map("description_en")
  descriptionFr     String?   @map("description_fr")
  price             Decimal   @db.Decimal(12, 2)
  currency          String    @default("XAF")
  categoryId        String    @map("category_id")
  category          Category  @relation(fields: [categoryId], references: [id])
  imageUrl          String?   @map("image_url")
  imageUrls         String[]  @map("image_urls")
  isActive          Boolean   @default(true) @map("is_active")
  ecoScore          Int       @default(0) @map("eco_score") // 0-100
  carbonKgPerUnit   Decimal?  @map("carbon_kg_per_unit") @db.Decimal(8, 4)
  recycledContent   Int?      @map("recycled_content") // percentage
  energyEfficiency  String?   @map("energy_efficiency") // A+, A, B, etc.
  certifications    String[]  // ISO 14001, Energy Star, etc.
  weight            Decimal?  @db.Decimal(8, 3) // kg
  stock             Stock?
  orderItems        OrderItem[]
  stockMovements    StockMovement[]
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@index([categoryId])
  @@index([isActive])
  @@map("products")
}

model Stock {
  id              String   @id @default(uuid())
  productId       String   @unique @map("product_id")
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity        Int      @default(0)
  reservedQty     Int      @default(0) @map("reserved_qty")
  lowStockAlert   Int      @default(5) @map("low_stock_alert")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("stocks")
}

model StockMovement {
  id          String            @id @default(uuid())
  productId   String            @map("product_id")
  product     Product           @relation(fields: [productId], references: [id])
  type        StockMovementType
  quantity    Int
  reason      String?
  reference   String?           // order ID or PO number
  createdAt   DateTime          @default(now()) @map("created_at")

  @@index([productId])
  @@map("stock_movements")
}

model Order {
  id              String        @id @default(uuid())
  orderNumber     String        @unique @map("order_number")
  userId          String        @map("user_id")
  user            User          @relation(fields: [userId], references: [id])
  addressId       String?       @map("address_id")
  address         Address?      @relation(fields: [addressId], references: [id])
  items           OrderItem[]
  subtotal        Decimal       @db.Decimal(12, 2)
  taxAmount       Decimal       @default(0) @map("tax_amount") @db.Decimal(12, 2)
  shippingAmount  Decimal       @default(0) @map("shipping_amount") @db.Decimal(12, 2)
  totalAmount     Decimal       @map("total_amount") @db.Decimal(12, 2)
  currency        String        @default("XAF")
  status          OrderStatus   @default(PENDING)
  paymentStatus   PaymentStatus @default(UNPAID) @map("payment_status")
  stripePaymentId String?       @map("stripe_payment_id")
  stripeSessionId String?       @map("stripe_session_id")
  payments        Payment[]
  totalCarbonKg   Decimal?      @map("total_carbon_kg") @db.Decimal(10, 4)
  notes           String?
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id          String  @id @default(uuid())
  orderId     String  @map("order_id")
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String  @map("product_id")
  product     Product @relation(fields: [productId], references: [id])
  nameSnapshot String  @map("name_snapshot") // frozen at order time
  quantity    Int
  unitPrice   Decimal @map("unit_price") @db.Decimal(12, 2)
  totalPrice  Decimal @map("total_price") @db.Decimal(12, 2)
  carbonKg    Decimal? @map("carbon_kg") @db.Decimal(8, 4)

  @@index([orderId])
  @@map("order_items")
}

model Subscription {
  id              String             @id @default(uuid())
  userId          String             @map("user_id")
  user            User               @relation(fields: [userId], references: [id])
  plan            SubscriptionPlan
  status          SubscriptionStatus @default(ACTIVE)
  paymentMethod   PaymentMethod?     @map("payment_method")
  // Stripe
  stripeSubId     String?            @map("stripe_sub_id")
  // Notchpay
  notchpayRef     String?            @map("notchpay_ref")
  startDate       DateTime           @map("start_date")
  endDate         DateTime?          @map("end_date")
  cancelledAt     DateTime?          @map("cancelled_at")
  priceXaf        Decimal            @map("price_xaf") @db.Decimal(12, 2)
  payments        Payment[]
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@map("subscriptions")
}

model Payment {
  id              String                   @id @default(uuid())
  userId          String                   @map("user_id")
  user            User                     @relation(fields: [userId], references: [id])
  subscriptionId  String?                  @map("subscription_id")
  subscription    Subscription?            @relation(fields: [subscriptionId], references: [id])
  orderId         String?                  @map("order_id")
  order           Order?                   @relation(fields: [orderId], references: [id])

  provider        PaymentProvider
  method          PaymentMethod
  amountXaf       Decimal                  @map("amount_xaf") @db.Decimal(12, 2)
  currency        String                   @default("XAF")

  // Référence unique retournée par le provider (Notchpay trx ref / Stripe session ID)
  providerRef     String?                  @unique @map("provider_ref")
  // ID abonnement chez le provider (Stripe sub ID / Notchpay subscription ref)
  providerSubRef  String?                  @map("provider_sub_ref")

  // Mobile Money — jamais le numéro complet, seulement un hint pour affichage
  phoneHint       String?                  @map("phone_hint") // ex: "****1234"

  status          PaymentTransactionStatus @default(PENDING)
  failureReason   String?                  @map("failure_reason")
  webhookPayload  Json?                    @map("webhook_payload") // snapshot brut pour audit

  paidAt          DateTime?                @map("paid_at")
  expiresAt       DateTime?                @map("expires_at") // timeout Mobile Money (ex: +10 min)
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")

  @@index([userId])
  @@index([subscriptionId])
  @@index([orderId])
  @@index([status])
  @@map("payments")
}

model CarbonProfile {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  user          User     @relation(fields: [userId], references: [id])
  year          Int
  month         Int
  totalKgCo2    Decimal  @map("total_kg_co2") @db.Decimal(10, 4)
  savedKgCo2    Decimal  @map("saved_kg_co2") @db.Decimal(10, 4) // vs non-eco products
  ordersCount   Int      @map("orders_count")
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([userId, year, month])
  @@map("carbon_profiles")
}
